@model ClinicApp.ViewModels.CreateDoctorViewModel
@{
    ViewData["Title"] = "Add Doctor";
}

<div class="bg-light py-4 mb-4">
    <div class="container">
        <h1 class="fw-bold mb-0"><i class="fa fa-user-plus me-2 text-success"></i>Add New Doctor</h1>
        <p class="text-muted mb-0">Create a doctor account. Default password: <strong>Doctor123!</strong></p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="CreateDoctor" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="alert alert-danger small"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-semibold"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-semibold"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Email" class="form-label fw-semibold"></label>
                                <input asp-for="Email" class="form-control" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label fw-semibold"></label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Select...</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                    <option>Other</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SpecialtyId" class="form-label fw-semibold"></label>
                                <select asp-for="SpecialtyId" class="form-select"
                                        asp-items="@(new SelectList(Model.Specialties, "Id", "Name"))">
                                    <option value="">-- Select Specialty --</option>
                                </select>
                                <span asp-validation-for="SpecialtyId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LicenseNumber" class="form-label fw-semibold"></label>
                                <input asp-for="LicenseNumber" class="form-control" placeholder="LIC-12345" />
                                <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="YearsOfExperience" class="form-label fw-semibold"></label>
                                <input asp-for="YearsOfExperience" type="number" class="form-control" min="0" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConsultationFee" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="ConsultationFee" type="number" class="form-control" step="0.01" />
                                </div>
                            </div>
                            <div class="col-12">
                                <label asp-for="Bio" class="form-label fw-semibold"></label>
                                <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Short bio..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <a asp-action="Doctors" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success ms-auto">
                                <i class="fa fa-save me-1"></i>Create Doctor
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
