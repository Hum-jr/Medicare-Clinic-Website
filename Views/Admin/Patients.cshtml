@{
    ViewData["Title"] = "Patients";
    var patients = Model as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="bg-light py-4 mb-4">
    <div class="container">
        <h1 class="fw-bold mb-0"><i class="fa fa-users me-2 text-primary"></i>All Patients</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Blood Type</th>
                        <th>Appointments</th>
                        <th>Joined</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in patients)
                    {
                        <tr>
                            <td class="fw-semibold">@p.Name</td>
                            <td class="text-muted small">@p.Email</td>
                            <td class="text-muted small">@(p.PhoneNumber ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.BloodType?.ToString()))
                                {
                                    <span class="badge bg-danger">@p.BloodType</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td><span class="badge bg-primary-subtle text-primary">@p.AppointmentCount</span></td>
                            <td class="text-muted small">@p.CreatedAt.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
