@model ClinicApp.ViewModels.AppointmentDetailsViewModel
@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-primary text-white p-4">
                    <h4 class="mb-0 fw-bold"><i class="fa fa-calendar-check me-2"></i>Appointment Details</h4>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 d-flex justify-content-between">
                        <span class="text-muted">Status</span>
                        <span class="badge fs-6 bg-@(Model.Status == ClinicApp.Models.AppointmentStatus.Confirmed ? "success" : Model.Status == ClinicApp.Models.AppointmentStatus.Cancelled ? "danger" : "secondary")">
                            @Model.Status
                        </span>
                    </div>
                    <dl class="row g-2">
                        <dt class="col-sm-5 text-muted">Doctor</dt>
                        <dd class="col-sm-7 fw-semibold">@Model.DoctorName</dd>

                        <dt class="col-sm-5 text-muted">Specialty</dt>
                        <dd class="col-sm-7">@Model.Specialty</dd>

                        <dt class="col-sm-5 text-muted">Date</dt>
                        <dd class="col-sm-7">@Model.AppointmentDate.ToString("dddd, MMMM d, yyyy")</dd>

                        <dt class="col-sm-5 text-muted">Time</dt>
                        <dd class="col-sm-7">@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</dd>

                        <dt class="col-sm-5 text-muted">Reason</dt>
                        <dd class="col-sm-7">@(Model.ReasonForVisit ?? "—")</dd>

                        <dt class="col-sm-5 text-muted">Fee</dt>
                        <dd class="col-sm-7 fw-bold text-success">$@Model.ConsultationFee</dd>

                        <dt class="col-sm-5 text-muted">Booked On</dt>
                        <dd class="col-sm-7">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                    </dl>

                    @if (!string.IsNullOrEmpty(Model.DoctorNotes))
                    {
                        <div class="alert alert-info mt-3">
                            <strong><i class="fa fa-notes-medical me-2"></i>Doctor's Notes:</strong>
                            <p class="mb-0 mt-1">@Model.DoctorNotes</p>
                        </div>
                    }
                </div>
                <div class="card-footer bg-light p-3 d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left me-1"></i>Back
                    </a>
                    <a asp-action="Book" class="btn btn-primary ms-auto">
                        <i class="fa fa-plus me-1"></i>Book Another
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
