@model ClinicApp.ViewModels.DoctorScheduleViewModel
@{
    ViewData["Title"] = "My Schedule";
}

<div class="bg-light py-4 mb-4">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h1 class="fw-bold mb-0"><i class="fa fa-calendar me-2 text-primary"></i>My Schedule</h1>
        <form method="get" class="d-flex gap-2">
            <input type="date" name="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" class="form-control" />
            <button type="submit" class="btn btn-primary">View</button>
        </form>
    </div>
</div>

<div class="container pb-5">
    <h5 class="mb-3 text-muted">@Model.SelectedDate.ToString("dddd, MMMM d, yyyy")</h5>

    @if (!Model.Appointments.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center text-muted">
            <i class="fa fa-calendar-xmark fa-4x mb-3"></i>
            <h5>No appointments on this day</h5>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="list-group list-group-flush">
                @foreach (var a in Model.Appointments.OrderBy(x => x.StartTime))
                {
                    <div class="list-group-item px-4 py-3">
                        <div class="row align-items-center g-2">
                            <div class="col-auto text-center" style="width:70px">
                                <div class="fw-bold text-primary">@a.StartTime.ToString(@"hh\:mm")</div>
                                <small class="text-muted">@a.EndTime.ToString(@"hh\:mm")</small>
                            </div>
                            <div class="col">
                                <strong>@a.PatientName</strong>
                                @if (!string.IsNullOrEmpty(a.ReasonForVisit))
                                {
                                    <div class="text-muted small">@a.ReasonForVisit</div>
                                }
                            </div>
                            <div class="col-auto">
                                <span class="badge bg-@BadgeColor(a.Status) me-2">@a.Status</span>
                            </div>
                            <div class="col-auto d-flex gap-2">
                                @if (a.Status == ClinicApp.Models.AppointmentStatus.Confirmed || a.Status == ClinicApp.Models.AppointmentStatus.Pending)
                                {
                                    <form asp-action="MarkComplete" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.Id" />
                                        <button class="btn btn-sm btn-success" title="Mark Complete">
                                            <i class="fa fa-check me-1"></i>Done
                                        </button>
                                    </form>
                                }
                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#notesModal" data-id="@a.Id"
                                        data-notes="@a.DoctorNotes" data-status="@((int)a.Status)">
                                    <i class="fa fa-pen me-1"></i>Notes
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(a.DoctorNotes))
                        {
                            <div class="alert alert-light small mt-2 mb-0">
                                <i class="fa fa-note-sticky me-1"></i> @a.DoctorNotes
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Notes Modal -->
<div class="modal fade" id="notesModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Appointment Notes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateNotes" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="AppointmentId" id="notesId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Status</label>
                        <select name="Status" id="notesStatus" class="form-select">
                            @foreach (var s in Enum.GetValues<ClinicApp.Models.AppointmentStatus>())
                            {
                                <option value="@((int)s)">@s</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Doctor Notes</label>
                        <textarea name="DoctorNotes" id="notesText" class="form-control" rows="4"
                                  placeholder="Add notes, diagnosis, prescriptions..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Notes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('notesModal').addEventListener('show.bs.modal', function(e) {
        var btn = e.relatedTarget;
        document.getElementById('notesId').value = btn.dataset.id;
        document.getElementById('notesText').value = btn.dataset.notes || '';
        document.getElementById('notesStatus').value = btn.dataset.status;
    });
</script>
}

@functions {
    string BadgeColor(ClinicApp.Models.AppointmentStatus s) => s switch {
        ClinicApp.Models.AppointmentStatus.Completed => "success",
        ClinicApp.Models.AppointmentStatus.Cancelled => "danger",
        ClinicApp.Models.AppointmentStatus.Confirmed => "primary",
        _ => "warning"
    };
}
